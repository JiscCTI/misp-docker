# For secret generation, consider: openssl rand -base64 32 | openssl sha384
# The '/' character cannot be used in passwords.

# Change to OidcAuth.Oidc if using OIDC
AUTH_METHOD=basic
CLAMAV_HOSTNAME=misp_clamav
FQDN=misp.local
GPG_PASSPHRASE=misp
HTTP_PORT=80
HTTPS_PORT=443
MISP_EMAIL_ADDRESS=misp@local
MISP_EMAIL_NAME=MISP
MISP_HOSTNAME=misp_web
MODULES_HOSTNAME=misp_modules
MYSQL_DBNAME=misp
MYSQL_HOSTNAME=misp_db
MYSQL_PASSWORD=misp
MYSQL_ROOT_PASSWORD=misp
MYSQL_USERNAME=misp
OIDC_PROVIDER=example.com/auth/realms/realm/.well-known/openid-configuration
OIDC_CLIENT_ID=misp
OIDC_CLIENT_SECRET=misp
OIDC_ADMIN_ROLE=misp-admin-access
OIDC_ORG_ADMIN_ROLE=misp-org-admin-access
OIDC_SYNC_ROLE=misp-sync-access
OIDC_PUBLISHER_ROLE=misp-publisher-access
OIDC_API_ROLE=misp-api-access
OIDC_USER_ROLE=misp-access
OIDC_AUTH_METHOD=client-secret-jwt
OIDC_CODE_CHALLENGE_METHOD=S256
ORG_NAME=ORGNAME
REDIS_HOST=misp_redis
REDIS_MISP_DB=2
REDIS_PASSWORD=misp
REDIS_WORKER_DB=3
SMTP_HOSTNAME=localhost
SMTP_PASSWORD=misp
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=misp
WORKERS_HOSTNAME=misp_workers
WORKERS_PASSWORD=misp
